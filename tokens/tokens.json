{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "rosi": {
    "version": "0.2.0",
    "source": "ResonantOS Browser Extension UI",
    "lastUpdated": "2026-05-28"
  },
  "color": {
    "surface": {
      "base":     { "$value": "#1A1E21", "$type": "color", "$description": "Page background — darkest layer" },
      "raised":   { "$value": "#1E2327", "$type": "color", "$description": "Cards, panels — first elevation" },
      "overlay":  { "$value": "#262B30", "$type": "color", "$description": "Modals, dropdowns — second elevation" },
      "sunken":   { "$value": "#2A3038", "$type": "color", "$description": "Inset areas, wells" },
      "hover":    { "$value": "#323940", "$type": "color", "$description": "Hover state on raised surfaces" }
    },
    "border": {
      "default":  { "$value": "#323940", "$type": "color", "$description": "Default border on surfaces" },
      "subtle":   { "$value": "#262B30", "$type": "color", "$description": "Subtle divider, separator" },
      "strong":   { "$value": "#6B7280", "$type": "color", "$description": "Active focus ring, emphasis border" }
    },
    "text": {
      "primary":   { "$value": "#E8EAED", "$type": "color", "$description": "Headings, body text — highest contrast" },
      "secondary": { "$value": "#9AA0A6", "$type": "color", "$description": "Descriptions, metadata" },
      "tertiary":  { "$value": "#6B7280", "$type": "color", "$description": "Placeholder, disabled, hint" },
      "inverse":   { "$value": "#1A1E21", "$type": "color", "$description": "Text on accent backgrounds" }
    },
    "accent": {
      "default":    { "$value": "#8AB4A0", "$type": "color", "$description": "Primary accent — muted sage green" },
      "bright":     { "$value": "#6BC49F", "$type": "color", "$description": "Hover/active accent state" },
      "vivid":      { "$value": "#7ECFAA", "$type": "color", "$description": "Notification dot, badge pulse" },
      "dark":       { "$value": "#3D5A4D", "$type": "color", "$description": "Pressed state, deep accent" },
      "on-accent":  { "$value": "#1A1E21", "$type": "color", "$description": "Text/icons on accent backgrounds" }
    },
    "semantic": {
      "success":   { "$value": "#8AB4A0", "$type": "color", "$description": "Same as accent — running/healthy/success" },
      "warning":   { "$value": "#E5A84B", "$type": "color", "$description": "Caution, pending, attention needed" },
      "error":     { "$value": "#E06C75", "$type": "color", "$description": "Failure, critical, destructive action" },
      "info":      { "$value": "#8AB4A0", "$type": "color", "$description": "Same as accent — informational state" }
    },
    "chrome": {
      "tab-bar":     { "$value": "#292D32", "$type": "color", "$description": "Browser tab bar background" },
      "tab-active":  { "$value": "#1E2327", "$type": "color", "$description": "Active tab background" },
      "toolbar":     { "$value": "#1E2327", "$type": "color", "$description": "Toolbar / address bar background" }
    }
  },
  "typography": {
    "fontFamily": {
      "system": {
        "$value": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "$type": "fontFamily",
        "$description": "Default UI font — system-ui everywhere"
      },
      "display": {
        "$value": "'Inter', system-ui, -apple-system, sans-serif",
        "$type": "fontFamily",
        "$description": "Display/headings — Inter with system fallback"
      }
    },
    "fontSize": {
      "xs":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px — badges, labels, captions" },
      "sm":   { "$value": "0.875rem", "$type": "dimension", "$description": "14px — secondary text, metadata" },
      "base": { "$value": "1rem",     "$type": "dimension", "$description": "16px — body text default" },
      "lg":   { "$value": "1.125rem", "$type": "dimension", "$description": "18px — card titles" },
      "xl":   { "$value": "1.25rem",  "$type": "dimension", "$description": "20px — section headings" },
      "2xl":  { "$value": "1.5rem",   "$type": "dimension", "$description": "24px — page titles" },
      "3xl":  { "$value": "1.875rem", "$type": "dimension", "$description": "30px — hero/display" }
    },
    "fontWeight": {
      "normal":    { "$value": 400, "$type": "number" },
      "medium":    { "$value": 500, "$type": "number" },
      "semibold":  { "$value": 600, "$type": "number" },
      "bold":      { "$value": 700, "$type": "number" }
    },
    "lineHeight": {
      "tight":  { "$value": 1.25, "$type": "number", "$description": "Headings" },
      "normal": { "$value": 1.5,  "$type": "number", "$description": "Body text" },
      "relaxed":{ "$value": 1.75, "$type": "number", "$description": "Long-form, descriptions" }
    }
  },
  "spacing": {
    "xs":  { "$value": "0.25rem", "$type": "dimension", "$description": "4px — icon gaps, inline padding" },
    "sm":  { "$value": "0.5rem",  "$type": "dimension", "$description": "8px — compact spacing" },
    "md":  { "$value": "0.75rem", "$type": "dimension", "$description": "12px — standard padding" },
    "base":{ "$value": "1rem",    "$type": "dimension", "$description": "16px — default spacing" },
    "lg":  { "$value": "1.5rem",  "$type": "dimension", "$description": "24px — section gaps" },
    "xl":  { "$value": "2rem",    "$type": "dimension", "$description": "32px — large gaps" },
    "2xl": { "$value": "3rem",    "$type": "dimension", "$description": "48px — page sections" },
    "3xl": { "$value": "4rem",    "$type": "dimension", "$description": "64px — major separators" }
  },
  "borderRadius": {
    "sm":   { "$value": "0.375rem", "$type": "dimension", "$description": "6px — small elements, tags" },
    "base": { "$value": "0.5rem",   "$type": "dimension", "$description": "8px — buttons, inputs" },
    "lg":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px — cards, panels" },
    "xl":   { "$value": "1rem",     "$type": "dimension", "$description": "16px — modals, dialogs" }
  },
  "elevation": {
    "0": { "$value": "none",                                        "$type": "shadow", "$description": "Flat — no shadow" },
    "1": { "$value": "0 1px 2px rgba(0,0,0,0.1)",                  "$type": "shadow", "$description": "Subtle — barely there" },
    "2": { "$value": "0 2px 8px rgba(0,0,0,0.15)",                 "$type": "shadow", "$description": "Raised — floating cards" },
    "3": { "$value": "0 4px 16px rgba(0,0,0,0.2)",                 "$type": "shadow", "$description": "Prominent — modals" }
  },
  "motion": {
    "duration": {
      "fast":    { "$value": "150ms", "$type": "duration" },
      "normal":  { "$value": "250ms", "$type": "duration" },
      "slow":    { "$value": "400ms", "$type": "duration" },
      "deliberate": { "$value": "600ms", "$type": "duration" }
    },
    "easing": {
      "default":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",  "$type": "cubicBezier" },
      "in":       { "$value": "cubic-bezier(0.4, 0, 1, 1)",     "$type": "cubicBezier" },
      "out":      { "$value": "cubic-bezier(0, 0, 0.2, 1)",     "$type": "cubicBezier" },
      "bounce":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  },
  "zIndex": {
    "base":     { "$value": 0,     "$type": "number" },
    "dropdown": { "$value": 100,   "$type": "number" },
    "sticky":   { "$value": 200,   "$type": "number" },
    "overlay":  { "$value": 300,   "$type": "number" },
    "modal":    { "$value": 400,   "$type": "number" },
    "popover":  { "$value": 500,   "$type": "number" },
    "toast":    { "$value": 600,   "$type": "number" }
  }
}
