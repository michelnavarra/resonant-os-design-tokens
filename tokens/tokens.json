{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "rosi": {
    "version": "0.3.0",
    "source": "ResonantOS Browser Extension UI, aligned palette (Coherent Verdant)",
    "lastUpdated": "2026-06-15",
    "supersedes": "0.2.0 (sage green on blue-gray, doc-only)",
    "alignment": "path (c), coherent palette drawn from v0.2 sage family and current dev team vibrant green"
  },
  "color": {
    "surface": {
      "base":     { "$value": "#0F1411", "$type": "color", "$description": "Page background, dark green-warmth ground layer, replaces v0.2 blue-gray #1A1E21 and impl near-black #070a08" },
      "deep":     { "$value": "#0B100E", "$type": "color", "$description": "Deeper canvas for special surfaces (modals, system panels)" },
      "raised":   { "$value": "rgba(20, 28, 24, 0.72)", "$type": "color", "$description": "Cards, panels, first elevation. Translucent green-tinted, matches impl pattern" },
      "overlay":  { "$value": "rgba(28, 36, 31, 0.94)", "$type": "color", "$description": "Modals, dropdowns, context popovers, second elevation" },
      "sunken":   { "$value": "rgba(0, 0, 0, 0.20)", "$type": "color", "$description": "Inputs, wells, inset areas" },
      "hover":    { "$value": "rgba(255, 255, 255, 0.055)", "$type": "color", "$description": "Light overlay on hover (matches impl rgba(255,255,255,0.055))" }
    },
    "border": {
      "subtle":   { "$value": "rgba(63, 178, 134, 0.14)", "$type": "color", "$description": "Default card border, dividers, input borders. Green-tinted to match the brand, low alpha" },
      "default":  { "$value": "rgba(63, 178, 134, 0.20)", "$type": "color", "$description": "Default border on raised interactive surfaces" },
      "strong":   { "$value": "rgba(63, 178, 134, 0.40)", "$type": "color", "$description": "Active borders, hover emphasis" },
      "glow":     { "$value": "rgba(63, 178, 134, 0.55)", "$type": "color", "$description": "Focused card border, drag-over outline" }
    },
    "text": {
      "primary":   { "$value": "#EAF1EC", "$type": "color", "$description": "Headings, body text, green-tinted off-white. ~16.5:1 on surface-base" },
      "secondary": { "$value": "#A3B1A8", "$type": "color", "$description": "Descriptions, metadata, helper text. ~8.4:1 on surface-base" },
      "tertiary":  { "$value": "#6E7C73", "$type": "color", "$description": "Placeholders, disabled, hint. ~4.3:1 (AA Large, AA UI, not for body text)" },
      "on-accent": { "$value": "#06110D", "$type": "color", "$description": "Text/icons on accent backgrounds. ~7.4:1 on accent-default" }
    },
    "accent": {
      "default":   { "$value": "#3FB286", "$type": "color", "$description": "Primary accent, Coherent Verdant. Aligned green between v0.2 sage #8AB4A0 and impl phosphor #24d18f. ~7.2:1 on surface-base" },
      "bright":    { "$value": "#5DCE9F", "$type": "color", "$description": "Hover state on accent (lighter)" },
      "strong":    { "$value": "#2DA176", "$type": "color", "$description": "Pressed/active state (darker). Replaces impl #18bd7d" },
      "muted":     { "$value": "rgba(63, 178, 134, 0.12)", "$type": "color", "$description": "Subtle accent backgrounds, secondary button fill" },
      "tint":      { "$value": "rgba(63, 178, 134, 0.08)", "$type": "color", "$description": "Lighter accent tint for gradient overlays and card highlights" },
      "glow":      { "$value": "rgba(63, 178, 134, 0.18)", "$type": "color", "$description": "Radial gradient ambient accent (replaces impl rgba(36, 209, 143, 0.15))" },
      "on":        { "$value": "#06110D", "$type": "color", "$description": "Text/icons on accent backgrounds" }
    },
    "semantic": {
      "success":   { "$value": "#3FB286", "$type": "color", "$description": "Healthy, completed, online, same as accent-default (intentional: one chromatic story)" },
      "running":   { "$value": "#3FB286", "$type": "color", "$description": "Active agent state, same as accent-default" },
      "info":      { "$value": "#5BA3C7", "$type": "color", "$description": "Informational state, cool blue, distinguishable from accent green" },
      "warning":   { "$value": "#E5A84B", "$type": "color", "$description": "Caution, attention, pending. Warm amber" },
      "error":     { "$value": "#E06C75", "$type": "color", "$description": "Failure, critical, destructive action. Warm red" },
      "neutral":   { "$value": "#9AA0A6", "$type": "color", "$description": "Disabled, inactive, no semantic value" }
    },
    "chrome": {
      "tab-bar":     { "$value": "#1E2327", "$type": "color", "$description": "Browser tab bar background" },
      "tab-active":  { "$value": "#161B17", "$type": "color", "$description": "Active tab background, green-shifted from v0.2" },
      "toolbar":     { "$value": "#161B17", "$type": "color", "$description": "URL bar area background" }
    }
  },
  "typography": {
    "fontFamily": {
      "system": {
        "$value": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "$type": "fontFamily",
        "$description": "Default UI font, system-ui everywhere"
      },
      "display": {
        "$value": "'Inter', system-ui, -apple-system, sans-serif",
        "$type": "fontFamily",
        "$description": "Display/headings, Inter with system fallback. Note: current impl uses a serif display face; we are keeping Inter for portability"
      },
      "mono": {
        "$value": "ui-monospace, 'SF Mono', SFMono-Regular, Menlo, Consolas, monospace",
        "$type": "fontFamily",
        "$description": "Code, job IDs, data values. Replaces JetBrains Mono from v0.1"
      }
    },
    "fontSize": {
      "xs":   { "$value": "0.6875rem",  "$type": "dimension", "$description": "11px, eyebrow labels, badges (matches impl font-size: 0.7rem and 0.62rem patterns)" },
      "sm":   { "$value": "0.8125rem",  "$type": "dimension", "$description": "13px, body, secondary text, button labels" },
      "base": { "$value": "0.875rem",   "$type": "dimension", "$description": "14px, primary text, settings form labels" },
      "lg":   { "$value": "1.125rem",   "$type": "dimension", "$description": "18px, card titles" },
      "xl":   { "$value": "1.35rem",    "$type": "dimension", "$description": "~22px, section headings" },
      "2xl":  { "$value": "1.75rem",    "$type": "dimension", "$description": "28px, page-level titles" },
      "3xl":  { "$value": "clamp(2rem, 4vw, 4.4rem)", "$type": "dimension", "$description": "Hero/display, clamped responsive (matches impl addons-hero h1 pattern)" }
    },
    "fontWeight": {
      "normal":    { "$value": 400, "$type": "number" },
      "medium":    { "$value": 500, "$type": "number" },
      "semibold":  { "$value": 600, "$type": "number" },
      "bold":      { "$value": 700, "$type": "number" },
      "heavy":     { "$value": 800, "$type": "number", "$description": "Used in impl for body-strong and titles" },
      "extrabold": { "$value": 950, "$type": "number", "$description": "Used in impl for button labels, eyebrow labels, nav item strong. Distinct from bold 700, semibold weight 600 sits between bold and extrabold" }
    },
    "lineHeight": {
      "tight":   { "$value": 0.95, "$type": "number", "$description": "Display headlines (clamp 0.95-1.05)" },
      "snug":    { "$value": 1.25, "$type": "number", "$description": "Headings, titles" },
      "normal":  { "$value": 1.45, "$type": "number", "$description": "Body text, controls" },
      "relaxed": { "$value": 1.6,  "$type": "number", "$description": "Long-form, descriptions" }
    },
    "letterSpacing": {
      "tight":   { "$value": "-0.065em", "$type": "dimension", "$description": "Display headlines (matches impl h1 letter-spacing)" },
      "normal":  { "$value": "0",        "$type": "dimension" },
      "wide":    { "$value": "0.05em",   "$type": "dimension", "$description": "Small caps labels" },
      "wider":   { "$value": "0.14em",   "$type": "dimension", "$description": "Eyebrow labels (uppercase accent labels)" }
    }
  },
  "spacing": {
    "0":  { "$value": "0",         "$type": "dimension" },
    "1":  { "$value": "0.25rem",   "$type": "dimension", "$description": "4px, micro gaps" },
    "2":  { "$value": "0.5rem",    "$type": "dimension", "$description": "8px, compact padding, icon button inner" },
    "3":  { "$value": "0.75rem",   "$type": "dimension", "$description": "12px, card internal padding (matches impl 12-16px range)" },
    "4":  { "$value": "1rem",      "$type": "dimension", "$description": "16px, default spacing" },
    "5":  { "$value": "1.5rem",    "$type": "dimension", "$description": "24px, section gaps" },
    "6":  { "$value": "2rem",      "$type": "dimension", "$description": "32px, large gaps" },
    "7":  { "$value": "3rem",      "$type": "dimension", "$description": "48px, page sections" },
    "8":  { "$value": "4rem",      "$type": "dimension", "$description": "64px, major separators" }
  },
  "borderRadius": {
    "xs":   { "$value": "0.5rem",   "$type": "dimension", "$description": "8px, small elements" },
    "sm":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px, inputs, chips" },
    "base": { "$value": "1rem",     "$type": "dimension", "$description": "16px, buttons, small cards" },
    "lg":   { "$value": "1.25rem",  "$type": "dimension", "$description": "20px, cards" },
    "xl":   { "$value": "1.375rem", "$type": "dimension", "$description": "22px, large cards, modals" },
    "2xl":  { "$value": "1.5rem",   "$type": "dimension", "$description": "24px, settings subnav, large panels" },
    "full": { "$value": "9999px",   "$type": "dimension", "$description": "Pills, send button, avatars" }
  },
  "sizing": {
    "icon-xs":      { "$value": "12px", "$type": "dimension", "$description": "Inline action icons, badges" },
    "icon-sm":      { "$value": "14px", "$type": "dimension", "$description": "Toolbar action icons" },
    "icon-md":      { "$value": "16px", "$type": "dimension", "$description": "Primary inline icons" },
    "icon-lg":      { "$value": "20px", "$type": "dimension", "$description": "Rail item icons, button icons" },
    "icon-xl":      { "$value": "24px", "$type": "dimension", "$description": "Large standalone icons" },
    "avatar-sm":    { "$value": "20px", "$type": "dimension", "$description": "Inline avatar (rail project icon)" },
    "avatar-md":    { "$value": "30px", "$type": "dimension", "$description": "User card avatar" },
    "avatar-lg":    { "$value": "34px", "$type": "dimension", "$description": "Brand mark" },
    "send-btn":     { "$value": "38px", "$type": "dimension", "$description": "Send button diameter" },
    "icon-button":  { "$value": "34px", "$type": "dimension", "$description": "Square icon button hit area" },
    "control-sm":   { "$value": "32px", "$type": "dimension", "$description": "Compact control height (rail action, search input)" },
    "control-md":   { "$value": "38-40px", "$type": "dimension", "$description": "Standard control height (input, select)" },
    "touch-min":    { "$value": "42px", "$type": "dimension", "$description": "Touch mode minimum (body[data-density='touch'])" }
  },
  "elevation": {
    "0": { "$value": "none",                                    "$type": "shadow", "$description": "Flat, default. System uses tonal layering" },
    "1": { "$value": "0 1px 2px rgba(0,0,0,0.1)",              "$type": "shadow", "$description": "Subtle, barely there" },
    "2": { "$value": "0 18px 50px rgba(0,0,0,0.34)",           "$type": "shadow", "$description": "Popover/panel, modals, context popovers, dropdown menus" },
    "3": { "$value": "0 24px 90px rgba(0,0,0,0.55)",           "$type": "shadow", "$description": "Modal, full-screen overlays" }
  },
  "motion": {
    "duration": {
      "fast":       { "$value": "120ms", "$type": "duration", "$description": "Hover, opacity, transform" },
      "normal":     { "$value": "200ms", "$type": "duration", "$description": "Panel slide, tab switch, focus" },
      "slow":       { "$value": "350ms", "$type": "duration", "$description": "Page transition" },
      "deliberate": { "$value": "600ms", "$type": "duration", "$description": "Section open/close" }
    },
    "easing": {
      "default":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)",  "$type": "cubicBezier" },
      "in":       { "$value": "cubic-bezier(0.4, 0, 1, 1)",     "$type": "cubicBezier" },
      "out":      { "$value": "cubic-bezier(0, 0, 0.2, 1)",     "$type": "cubicBezier" },
      "bounce":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  },
  "zIndex": {
    "base":     { "$value": 0,    "$type": "number" },
    "rail":     { "$value": 10,   "$type": "number", "$description": "Sidebar nav layer" },
    "sticky":   { "$value": 20,   "$type": "number", "$description": "Sticky headers, content tabs" },
    "composer": { "$value": 30,   "$type": "number", "$description": "Input composer (sticky bottom)" },
    "dropdown": { "$value": 40,   "$type": "number", "$description": "Dropdowns, popovers" },
    "modal":    { "$value": 1000, "$type": "number", "$description": "Full-screen modals (matches impl settings-provider-modal)" }
  }
}
